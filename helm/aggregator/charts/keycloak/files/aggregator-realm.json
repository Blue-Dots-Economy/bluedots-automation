{
  "realm": "aggregator",
  "enabled": true,
  "sslRequired": "none",
  "displayName": "Blue Dots Aggregator",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,
  "verifyEmail": false,
  "loginTheme": "otp",
  "emailTheme": "otp",
  "accountTheme": "keycloak.v3",
  "adminTheme": "keycloak.v2",
  "internationalizationEnabled": true,
  "supportedLocales": ["en"],
  "defaultLocale": "en",
  "attributes": {
    "phoneDefaultRegion": "IN",
    "userProfileEnabled": "true",
    "kc.user.profile.config": "{\"unmanagedAttributePolicy\":\"ENABLED\",\"attributes\":[{\"name\":\"username\",\"displayName\":\"${username}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"email\",\"displayName\":\"${email}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"required\":{\"roles\":[\"user\"]}},{\"name\":\"firstName\",\"displayName\":\"${firstName}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"lastName\",\"displayName\":\"${lastName}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"phoneNumber\",\"displayName\":\"Phone Number\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"phoneNumberVerified\",\"displayName\":\"Phone Number Verified\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}}]}"
  },
  "smtpServer": {
    "host": "__SMTP_HOST__",
    "port": "__SMTP_PORT__",
    "from": "__SMTP_FROM__",
    "fromDisplayName": "__SMTP_FROM_DISPLAY__",
    "ssl": "__SMTP_SSL__",
    "starttls": "__SMTP_STARTTLS__",
    "auth": "__SMTP_AUTH__",
    "user": "__SMTP_USER__",
    "password": "__SMTP_PASSWORD__"
  },
  "authenticationFlows": [
    {
      "alias": "aggregator-otp-browser",
      "description": "Browser flow: identifier (email/phone/username) then OTP via auto-routed channel",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-cookie",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 10
        },
        {
          "authenticatorFlow": true,
          "requirement": "ALTERNATIVE",
          "priority": 20,
          "flowAlias": "aggregator-otp-forms"
        }
      ]
    },
    {
      "alias": "aggregator-otp-forms",
      "description": "Identifier resolution then OTP channel choice + verify",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "otp-identifier-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10
        },
        {
          "authenticator": "otp-channel-choice-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 20,
          "authenticatorConfig": "aggregator-otp-choice-config"
        }
      ]
    }
  ],
  "authenticatorConfig": [
    {
      "alias": "aggregator-otp-choice-config",
      "config": {
        "otpChoice.codeLength": "6",
        "otpChoice.ttl": "300",
        "otpChoice.maxRetries": "3",
        "otpChoice.phoneAttribute": "phoneNumber"
      }
    }
  ],
  "browserFlow": "aggregator-otp-browser",
  "directGrantFlow": "direct grant",
  "clients": [
    {
      "clientId": "aggregator-portal",
      "name": "Aggregator Portal (BFF)",
      "description": "Confidential OIDC client for the Blue Dots Aggregator portal — Authorization Code + PKCE with client secret; tokens held server-side by Next.js BFF.",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__OIDC_CLIENT_SECRET__",
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/api/auth/callback",
        "http://localhost:3100/api/auth/callback",
        "http://localhost/api/auth/callback",
        "__PUBLIC_BASE_URL__/api/auth/callback"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:3100",
        "http://localhost",
        "__PUBLIC_BASE_URL__"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/##http://localhost:3000/login##http://localhost:3100/##http://localhost:3100/login##http://localhost/##http://localhost/login##__PUBLIC_BASE_URL__/##__PUBLIC_BASE_URL__/login",
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "aggregator_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "aggregator_id",
            "claim.name": "aggregator_id",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        },
        {
          "name": "decision_made",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "decision_made",
            "claim.name": "decision_made",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        },
        {
          "name": "aggregator_type",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "aggregator_type",
            "claim.name": "aggregator_type",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        },
        {
          "name": "phone_number",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "phoneNumber",
            "claim.name": "phone_number",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        }
      ]
    },
    {
      "clientId": "aggregator-api",
      "name": "Aggregator API (service account)",
      "description": "Confidential client used by apps/api for Keycloak admin operations (create user on registration approval, etc.). Service account holds only realm-management:manage-users.",
      "enabled": true,
      "publicClient": false,
      "secret": "__BFF_SERVICE_CLIENT_SECRET__",
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "attributes": {
        "use.refresh.tokens": "false"
      }
    }
  ],
  "users": [
    {
      "username": "service-account-aggregator-api",
      "enabled": true,
      "serviceAccountClientId": "aggregator-api",
      "clientRoles": {
        "realm-management": ["view-users", "manage-users", "query-users"]
      }
    },
    {
      "username": "testuser",
      "enabled": true,
      "email": "testuser@example.com",
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "attributes": {
        "phoneNumber": ["+919876543210"],
        "phoneNumberVerified": ["true"]
      },
      "realmRoles": ["default-roles-aggregator"]
    },
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@example.com",
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Provider",
      "attributes": {
        "phoneNumber": ["+919812345678"],
        "phoneNumberVerified": ["true"]
      },
      "realmRoles": ["default-roles-aggregator"]
    }
  ]
}

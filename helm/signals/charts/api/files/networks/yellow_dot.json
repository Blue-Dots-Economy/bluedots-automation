{
  "display_name": "Yellow Dot",
  "description": "Education focused DOT.",
  "schema_standard": "https://json-schema.org/draft/2020-12/schema",
  "domains": [
    {
      "description": "Learners on the network.",
      "minimum_cache_ttl_seconds": 300,
      "status_rules": [
        { "status": "new",      "when": { "item_age_days": { "lte": 7 } } },
        { "status": "active",   "when": { "days_since_last": { "buckets": ["create", "accept"], "lte": 30 } } },
        { "status": "at_risk",  "when": { "days_since_last": { "buckets": ["create", "accept", "reject"], "between": [31, 90] } } },
        { "status": "inactive", "when": "default" }
      ],
      "item_schemas": {
        "profile_1.0": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "Student Profile 1.0",
          "display_name_field": "Full Name",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "Student ID",
            "Full Name",
            "Phone Number",
            "Email Address",
            "Location",
            "Grade",
            "Academic Stream",
            "Service Looking For"
          ],
          "properties": {
            "Student ID": {
              "type": "string",
              "minLength": 1
            },
            "Full Name": {
              "type": "string",
              "minLength": 1
            },
            "Phone Number": {
              "type": "string",
              "pattern": "^[0-9]{10}$",
              "private": true
            },
            "Email Address": {
              "type": "string",
              "format": "email",
              "private": true
            },
            "Location": {
              "type": "string",
              "minLength": 1,
              "location": "primary"
            },
            "Grade": {
              "type": "string",
              "enum": [
                "Class XI",
                "Class XII",
                "Post-XII"
              ]
            },
            "Academic Stream": {
              "type": "string",
              "enum": [
                "Science",
                "Commerce",
                "Arts",
                "Other"
              ]
            },
            "Service Looking For": {
              "type": "string",
              "enum": [
                "Subject Tutoring",
                "Admission Guidance",
                "Career Counseling",
                "Skills Workshop"
              ]
            }
          }
        }
      },
      "id": "student",
      "card": {
        "title_field": "Full Name",
        "avatar_from": "Full Name",
        "default_fields": ["Location", "Grade", "Academic Stream", "Service Looking For"]
      },
      "dashboard_tiles": {
        "profile": [
          { "field": "total_items", "label": "Profiles Registered" },
          { "field": "complete_profiles", "label": "Profiles Complete" },
          { "field": "has_applications", "label": "Has Activity" }
        ],
        "user": [
          { "field": "total_users", "label": "Total Students" },
          { "field": "avg_items_per_user", "label": "Avg Profiles per Student" }
        ]
      }
    },
    {
      "description": "Individual tutors, WEERA members, and counsellors on the network.",
      "minimum_cache_ttl_seconds": 300,
      "status_rules": [
        { "status": "new",      "when": { "item_age_days": { "lte": 7 } } },
        { "status": "active",   "when": { "days_since_last": { "buckets": ["create", "accept"], "lte": 30 } } },
        { "status": "at_risk",  "when": { "days_since_last": { "buckets": ["create", "accept", "reject"], "between": [31, 90] } } },
        { "status": "inactive", "when": "default" }
      ],
      "item_schemas": {
        "profile_1.0": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "Individual Tutor / WEERA / Counsellor Profile 1.0",
          "display_name_field": "Full Name",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "Tutor ID",
            "Full Name",
            "Phone Number",
            "Email Address",
            "Location",
            "Coverage Radius (km)",
            "Service Offered",
            "Grade Bands Served",
            "Academic Streams Served"
          ],
          "properties": {
            "Tutor ID": {
              "type": "string",
              "minLength": 1
            },
            "Full Name": {
              "type": "string",
              "minLength": 1
            },
            "Phone Number": {
              "type": "string",
              "pattern": "^[0-9]{10}$",
              "private": true
            },
            "Email Address": {
              "type": "string",
              "format": "email",
              "private": true
            },
            "Location": {
              "type": "string",
              "minLength": 1
            },
            "Coverage Radius (km)": {
              "type": "number",
              "minimum": 0
            },
            "Service Offered": {
              "type": "string",
              "enum": [
                "Subject Tutoring",
                "Test Preparation",
                "Career Counseling",
                "Skills Workshop"
              ]
            },
            "Grade Bands Served": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "Class XI",
                  "Class XII",
                  "Post-XII"
                ]
              }
            },
            "Academic Streams Served": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "Science",
                  "Commerce",
                  "Arts",
                  "Other"
                ]
              }
            }
          }
        }
      },
      "id": "individual_tutor_weera_counsellor",
      "card": {
        "title_field": "Full Name",
        "avatar_from": "Full Name",
        "default_fields": ["Location", "Service Offered", "Grade Bands Served", "Academic Streams Served"]
      },
      "dashboard_tiles": {
        "profile": [
          { "field": "total_items", "label": "Profiles Registered" },
          { "field": "complete_profiles", "label": "Profiles Complete" },
          { "field": "has_applications", "label": "Has Activity" }
        ],
        "user": [
          { "field": "total_users", "label": "Total Tutors" },
          { "field": "avg_items_per_user", "label": "Avg Profiles per Tutor" }
        ]
      }
    }
  ],
  "instances": [
    {
      "instance_name": "Yellow Dot Student Local",
      "instance_url": "__PUBLIC_API_URL__",
      "custom_item_schema_urls": {},
      "domain_id": "student"
    },
    {
      "instance_name": "Yellow Dot Tutor Local",
      "instance_url": "__PUBLIC_API_URL__",
      "custom_item_schema_urls": {},
      "domain_id": "individual_tutor_weera_counsellor"
    },
    {
      "instance_name": "Yellow Dot Student",
      "instance_url": "https://ubi-backend1.onest.dhiway.net",
      "custom_item_schema_urls": {},
      "domain_id": "student"
    },
    {
      "instance_name": "Yellow Dot Tutor",
      "instance_url": "https://ubi-backend1.onest.dhiway.net",
      "custom_item_schema_urls": {},
      "domain_id": "individual_tutor_weera_counsellor"
    }
  ],
  "actions": {
    "connect": {
      "description": "Defines which domains can connect to which other domains, what requirement payload they send, and what event payload is returned.",
      "interactions": [
        {
          "from_network": "onest_yellow_dot",
          "from_domain": "student",
          "to_network": "onest_yellow_dot",
          "to_domain": "individual_tutor_weera_counsellor",
          "requirement_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Student To Individual Tutor Connect Requirement",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "Service Looking For",
              "Grade",
              "Academic Stream",
              "What are you looking to achieve?"
            ],
            "properties": {
              "Service Looking For": {
                "type": "string",
                "enum": [
                  "Subject Tutoring",
                  "Admission Guidance",
                  "Career Counseling",
                  "Skills Workshop"
                ]
              },
              "Grade": {
                "type": "string",
                "enum": [
                  "Class XI",
                  "Class XII",
                  "Post-XII"
                ]
              },
              "Academic Stream": {
                "type": "string",
                "enum": [
                  "Science",
                  "Commerce",
                  "Arts",
                  "Other"
                ]
              },
              "What are you looking to achieve?": {
                "type": "string"
              }
            }
          },
          "event_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Student To Individual Tutor Connect Event",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "remark"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "created",
                  "accepted",
                  "rejected"
                ]
              },
              "remark": {
                "type": "string"
              }
            }
          }
        },
        {
          "from_network": "onest_yellow_dot",
          "from_domain": "individual_tutor_weera_counsellor",
          "to_network": "onest_yellow_dot",
          "to_domain": "student",
          "requirement_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Individual Tutor To Student Connect Requirement",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "Introduction Message"
            ],
            "properties": {
              "Introduction Message": {
                "type": "string"
              }
            }
          },
          "event_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "Individual Tutor To Student Connect Event",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "remark"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "created",
                  "accepted",
                  "rejected"
                ]
              },
              "remark": {
                "type": "string"
              }
            }
          }
        }
      ]
    }
  },
  "id": "onest_yellow_dot",
  "dashboard_buckets": {
    "by_status": {
      "new": "New",
      "active": "Active",
      "at_risk": "At Risk",
      "inactive": "Inactive"
    },
    "by_initiated_action_status": {
      "create": "Created",
      "accept": "Accepted",
      "reject": "Rejected",
      "cancel": "Cancelled"
    },
    "by_received_action_status": {
      "create": "Requests",
      "accept": "Accepted",
      "reject": "Rejected",
      "cancel": "Cancelled"
    }
  }
}
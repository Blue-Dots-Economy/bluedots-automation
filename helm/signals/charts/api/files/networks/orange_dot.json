{
  "display_name": "Orange Dots",
  "description": "Tourism, Arts & Culture discovery network — Udupi district (PWA + voice via Tourist Saarthi).",
  "schema_standard": "https://json-schema.org/draft/2020-12/schema",
  "domains": [
    {
      "description": "Practitioners — surf instructors, guides, artisans, homestays, GI suppliers, temple trusts, curated experiences. One Orange Dot per supplier / listing.",
      "minimum_cache_ttl_seconds": 300,
      "status_rules": [
        {
          "status": "new",
          "label": "New",
          "description": "Listed within the last 7 days",
          "when": {
            "item_age_days": {
              "lte": 7
            }
          }
        },
        {
          "status": "active",
          "label": "Active",
          "description": "A live, published listing",
          "when": "default"
        }
      ],
      "item_schemas": {
        "profile_1.0": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "Orange Dot Practitioner Listing 1.0",
          "display_name_field": "name",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "category",
            "description",
            "area",
            "contact_phone"
          ],
          "properties": {
            "name": {
              "type": "string",
              "title": "Name",
              "description": "Display name of your listing or experience.",
              "minLength": 1
            },
            "category": {
              "type": "string",
              "title": "Category",
              "description": "What kind of listing this is.",
              "enum": [
                "Stay",
                "Artists",
                "Activities",
                "GI Products",
                "Curated"
              ]
            },
            "description": {
              "type": "string",
              "title": "Description",
              "description": "A short blurb shown on your listing card.",
              "minLength": 1,
              "maxLength": 280
            },
            "provider_name": {
              "type": "string",
              "title": "Provider Name",
              "description": "Your business or organisation name."
            },
            "area": {
              "type": "string",
              "title": "Area",
              "description": "Locality or town within Udupi district.",
              "location": "single"
            },
            "contact_phone": {
              "type": "string",
              "title": "Contact Phone",
              "description": "Your 10-digit contact number — shown publicly so travellers can reach you directly.",
              "pattern": "^[0-9]{10}$"
            },
            "services": {
              "type": "array",
              "title": "Services",
              "description": "What you offer.",
              "items": {
                "type": "string",
                "enum": [
                  "Stay",
                  "Food & Dining",
                  "Experiences & Activities",
                  "Crafts / GI Products",
                  "Guided Tours",
                  "Cultural / Spiritual",
                  "Transport",
                  "Wellness"
                ]
              }
            },
            "languages": {
              "type": "array",
              "title": "Languages",
              "description": "Languages you can support.",
              "items": {
                "type": "string",
                "enum": [
                  "English",
                  "Hindi",
                  "Kannada",
                  "Tulu",
                  "Konkani",
                  "Others"
                ]
              }
            },
            "pricing": {
              "type": "string",
              "title": "Pricing",
              "description": "Your typical price range.",
              "enum": [
                "Economical",
                "Moderate",
                "Premium"
              ]
            },
            "website": {
              "type": "string",
              "title": "Website",
              "description": "Your website, if any.",
              "format": "uri"
            }
          }
        }
      },
      "id": "practitioner",
      "card": {
        "title_field": "name",
        "avatar_from": "name",
        "default_fields": [
          "category",
          "area",
          "pricing",
          "services"
        ]
      },
      "dashboard_tiles": {
        "profile": [
          {
            "field": "total_items",
            "label": "Listings Registered"
          },
          {
            "field": "complete_profiles",
            "label": "Verified Listings"
          },
          {
            "field": "has_applications",
            "label": "Received Connections"
          }
        ],
        "user": [
          {
            "field": "total_users",
            "label": "Total Orange Dots"
          },
          {
            "field": "avg_items_per_user",
            "label": "Avg Listings per Orange Dot"
          }
        ]
      }
    }
  ],
  "instances": [
    {
      "instance_name": "Orange Dot Practitioner Local",
      "instance_url": "__PUBLIC_API_URL__",
      "custom_item_schema_urls": {},
      "domain_id": "practitioner"
    }
  ],
  "actions": {},
  "id": "orange_dot",
  "dashboard_buckets": {
    "by_status": {
      "new": "New",
      "active": "Active"
    }
  }
}
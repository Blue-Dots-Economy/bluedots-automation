variable "base_location" {
  description = "Absolute path of the terragrunt unit directory (used as the anchor for the generated yaml file location)"
  type        = string
}

variable "building_block" {
  description = "Naming prefix used for all resources"
  type        = string
}

variable "environment" {
  description = "Environment name"
  type        = string
}

variable "cloud_storage_provider" {
  description = "Cloud storage provider tag (e.g. aws)"
  type        = string
  default     = "aws"
}

variable "cloud_storage_region" {
  description = "AWS region for all resources"
  type        = string
}

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------
variable "vpc_id" {
  type    = string
  default = ""
}

variable "vpc_cidr_block" {
  type    = string
  default = ""
}

variable "public_subnet_ids" {
  type    = list(string)
  default = []
}

variable "private_subnet_ids" {
  type    = list(string)
  default = []
}

variable "nat_gateway_public_ip" {
  type    = string
  default = ""
}

# -----------------------------------------------------------------------------
# EKS
# -----------------------------------------------------------------------------
variable "cluster_name" {
  type    = string
  default = ""
}

variable "cluster_endpoint" {
  type    = string
  default = ""
}

variable "cluster_arn" {
  type    = string
  default = ""
}

variable "oidc_provider_arn" {
  type    = string
  default = ""
}

variable "oidc_provider" {
  type    = string
  default = ""
}

variable "node_role_arn" {
  type    = string
  default = ""
}

variable "private_ingressgateway_ip" {
  type    = string
  default = ""
}

variable "cloudwatch_observability_role_arn" {
  type    = string
  default = ""
}

# -----------------------------------------------------------------------------
# IAM (IRSA)
# -----------------------------------------------------------------------------
variable "app_sa_role_arn" {
  type    = string
  default = ""
}

variable "app_sa_role_name" {
  type    = string
  default = ""
}

# -----------------------------------------------------------------------------
# Storage (S3)
# -----------------------------------------------------------------------------
variable "storage_bucket_public" {
  type    = string
  default = ""
}

variable "storage_bucket_private" {
  type    = string
  default = ""
}

# -----------------------------------------------------------------------------
# Random secrets (generated by the random_passwords module)
# -----------------------------------------------------------------------------
variable "random_string" {
  type      = string
  sensitive = true
}

variable "encryption_string" {
  type      = string
  sensitive = true
  validation {
    condition     = length(var.encryption_string) == 32
    error_message = "encryption_string must be exactly 32 characters."
  }
}

variable "keycloak_password" {
  type      = string
  sensitive = true
  default   = ""
}

variable "postgresql_password" {
  type      = string
  sensitive = true
  default   = ""
}

variable "redis_password" {
  type      = string
  sensitive = true
  default   = ""
}

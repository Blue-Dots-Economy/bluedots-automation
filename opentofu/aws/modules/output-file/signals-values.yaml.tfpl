# signals chart overlay — values at ROOT so helm reads them directly.
# Generated by opentofu (modules/output-file). Do NOT edit or commit.
#
# IMPORTANT: parent helm/signals/values.yaml binds subchart secrets at
# parse-time via YAML anchors (e.g. `api.secrets: *api_secrets`). That snapshot
# captures the EMPTY default values, so overriding credentials.api.data here
# would never reach subchart pods. We therefore override directly at the
# subchart paths (api.secrets.data, notification-service.secrets.data, …).
# credentials.* still gets populated so signals/templates/secrets.yaml can
# render the dpg-postgres + dpg-redis existingSecret bridges.

# Public FQDNs for the api + ui ingress. publicHosts is the SOLE source of the
# served hostnames — both the ui and api ingresses range over it (every host
# that serves the UI also serves /api, same-origin per portal). One multi-SAN
# cert covers all hosts. All other ingress config lives in helm/signals/values.yaml.
global:
  publicHosts:
%{ for h in signals_public_hosts ~}
    - ${h}
%{ endfor ~}

credentials:
  postgresql:
    password: "${signals_postgres_password}"
  redis:
    password: "${signals_redis_password}"

api:
  secrets:
    create: true
    existingSecret: dpg-api-secrets
    authSecret: "${signals_auth_secret}"
    notificationKeyId: "dpg-api-client"
    notificationSecret: "${signals_notification_secret}"
    data:
      AUTH_SECRET: "${signals_auth_secret}"
      # PII encryption key — generated via `openssl rand -base64 32` equivalent
      # (random_id.signals_pii_key.b64_std).
      SIGNALS_PII_KEY: "${signals_pii_key}"
      POSTGRES_PASSWORD: "${signals_postgres_password}"
      REDIS_PASSWORD: "${signals_redis_password}"
      AGGREGATOR_DPG_API_KEY: "${signalstack_admin_key}"
      # Chart default points at dpg-notification-service (release `dpg`); this
      # release is `signals`, so the service is signals-notification-service.
      NOTIFICATION_SERVICE_ENDPOINT: "http://signals-notification-service:3000"
      NOTIFICATION_SERVICE_SECRET: "${signals_notification_secret}"
      DPG_SCORING_SECRET: "${signals_dpg_scoring_secret}"
      GOOGLE_GEOCODING_API_KEY: "${signals_google_maps_api_key}"
  # Postgres now points at AWS RDS (managed); Redis stays in-cluster via the
  # common-services release FQDN (common-services-redis-master).
  postgres:
    host: "${postgres_host}"
  redis:
    host: common-services-redis-master.common-services.svc.cluster.local
  config:
    # Canonical public host = first of publicHosts. For multi-domain, both
    # portals are same-origin (host/ + host/api); ALLOWED_ORIGINS lists every host.
    API_DOMAIN: https://${signals_public_hosts[0]}
    ALLOWED_ORIGINS: "${signals_allowed_origins}"
    # Per-domain bindings the API serves (roles differ per network).
    SERVED_DOMAINS: "${signals_served_domains}"
    NETWORK_CONFIG_LOCAL_FILE: "/app/schemas/${signals_network}.json"
  schemas:
    networks:
      - ${signals_network}
    # apiInternalUrl / crossNetworkUrl intentionally omitted: they fall back to
    # the chart default http://signals-api:2742 (the in-cluster signals API).
    # instance_url substitution + server-side inter-instance fetch use the
    # in-cluster service directly; no public host needed here.

ui:
  # nginx proxies /api/* to the in-cluster signals API. The chart default
  # (http://dpg-api:2742) assumes a release named `dpg`; this release is
  # `signals`, so the service is `signals-api`. Wrong upstream = blank UI.
  apiUpstream: "http://signals-api:2742"
  # Exposed to the ui container as the UI_VARIANT env var (chart default: signals).
  uiVariant: "signals"
%{ if signals_host_bindings != "" ~}
  # Host -> VITE_SERVED_BINDINGS map (host-routed served binding). When set,
  # config.js is forced to the "__SERVED_BINDINGS__" placeholder the UI image's
  # nginx rewrites per request by Host header, so ONE instance backs several
  # per-domain portals. REQUIRES a UI image with UI_HOST_BINDINGS support.
  hostBindings: "${signals_host_bindings}"
%{ endif ~}
  runtimeConfig:
    VITE_DEFAULT_VIEW_MODE: "map"
    VITE_MAP_PROVIDER: "google-maps"
    VITE_GOOGLE_MAPS_API_KEY: "${signals_google_maps_api_key}"
    VITE_ACTION_POLL_INTERVAL_MS: "30000"
    # Show only the network this cluster serves (chart default is purple_dot).
    VITE_NETWORK_NAME: "${signals_network}"
    VITE_ANALYTICS_GA_ID: ""
  service:
    # nginx in the ui image listens on 80; chart default targetPort 8080
    # would leave readiness probe hitting a closed port. Pin to 80.
    port: 80
    targetPort: 80

notification-service:
  secrets:
    create: true
    existingSecret: ""
    data:
      REDIS_PASSWORD: "${signals_redis_password}"
      GMAIL_USER: "${notification_gmail_user}"
      GMAIL_PASS: "${notification_gmail_pass}"
      MSG91_AUTH_KEY: "${notification_msg91_auth_key}"
      MSG91_TEMPLATE_ID: "${notification_msg91_template_id}"
  redis:
    host: common-services-redis-master.common-services.svc.cluster.local
  internalSecrets:
    create: true
    existingSecret: ""
    fileName: internal-secrets.json
    mountPath: /app/config
    # Must match api.secrets.notificationSecret (HMAC partner).
    json: |
      {
        "dpg-api-client": {
          "secret": "${signals_notification_secret}"
        }
      }

match-score:
  secrets:
    create: true
    data:
      REDIS_PASSWORD: "${signals_redis_password}"
  redis:
    host: common-services-redis-master.common-services.svc.cluster.local
  configFiles:
    create: true
    authKeysJson: |
      {
        "keys": [
          {
            "keyId": "match-score-client",
            "secret": "${signals_dpg_scoring_secret}"
          }
        ]
      }
    aiProvidersFileName: ai.providers.local.json
    # Schema (validated by zod in dpg-scoring/src/lib/ai/provider-secrets.ts):
    #   { providers: { <name>: { apiKey: string }, ... } }
    # <name> must match config.MATCH_SCORE_PROVIDER above (default: openai).
    # update the Key for the respective provider you will opt for.
    aiProvidersJson: |
      {
        "providers": {
          "openai": {
            "apiKey": "REPLACE_WITH_OPENAI_API_KEY"
          },
          "gemini": {
            "apiKey": "REPLACE_WITH_GEMINI_API_KEY"
          }
        }
      }

# Signals search: inject the shared DB/Redis passwords into the
# dpg-search-secrets Secret (same generated values as the api block above).
search:
  secrets:
    create: true
    existingSecret: dpg-search-secrets
    data:
      POSTGRES_USER: "dpg"
      POSTGRES_DB: "dpg"
      POSTGRES_PASSWORD: "${signals_postgres_password}"
      REDIS_PASSWORD: "${signals_redis_password}"
      EMBEDDING_API_KEY: ""

# global-secrets.yaml — operator-provided secrets overlay (#1.2a)
# =============================================================================
# Copy this file to `global-secrets.yaml` (same directory) and fill in the REAL
# secret values. `global-secrets.yaml` is GITIGNORED and must NEVER be committed.
#
# install.sh layers this file **LAST** in every helm deploy (after
# global-values.yaml AND the generated global-credentials.yaml), so the values
# here override the committed placeholders — keeping real secrets out of every
# committed file. When the file is absent, deploys behave exactly as before.
#
# Only the genuinely user-provided secrets belong here (SMTP / MSG91 / Gmail /
# Maps). The auto-generated secrets (DB/Redis/auth passwords, PII key, etc.)
# stay in the generated global-credentials.yaml — do NOT duplicate them here.
#
# The committed global-values.yaml keeps only NON-secret config (SMTP host/port,
# from-display, MSG91 template id) and placeholder anchors; put nothing secret
# there. Keys below match each chart's schema (same paths global-credentials.yaml
# uses), so they deep-merge over the generated file.
# =============================================================================

# ─── monitoring chart — Alertmanager SMTP (Gmail App Password) ───────────────
alerting:
  email:
    smtpFrom: "sender@example.com"
    smtpAuthUsername: "sender@example.com"
    smtpAuthPassword: "REPLACE_WITH_GMAIL_APP_PASSWORD"

# ─── signals chart — api geocoding + notification-service SMTP/MSG91 ─────────
api:
  secrets:
    data:
      GOOGLE_GEOCODING_API_KEY: "REPLACE_WITH_GOOGLE_MAPS_API_KEY"

notification-service:
  secrets:
    data:
      GMAIL_USER: "sender@example.com"
      GMAIL_PASS: "REPLACE_WITH_GMAIL_APP_PASSWORD"
      MSG91_AUTH_KEY: "REPLACE_WITH_MSG91_AUTH_KEY"

# ─── signals chart — UI Google Maps key (public, but still deploy-config) ────
ui:
  runtimeConfig:
    VITE_GOOGLE_MAPS_API_KEY: "REPLACE_WITH_GOOGLE_MAPS_API_KEY"

# ─── aggregator chart — SMTP + MSG91 ─────────────────────────────────────────
secrets:
  smtpUser: "sender@example.com"
  smtpPassword: "REPLACE_WITH_GMAIL_APP_PASSWORD"
  msg91AuthKey: "REPLACE_WITH_MSG91_AUTH_KEY"

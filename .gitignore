# Helm install-time generated secrets / overrides (never commit).
helm/**/values.local.yaml

# Tarballs auto-generated by `helm dependency update` for charts that are
# intentionally vendored as extracted directories — ignore all except
# metrics-server which is kept as a tarball only (no extracted directory).
helm/common-services/charts/cert-manager-*.tgz
helm/common-services/charts/ingress-nginx-*.tgz
helm/common-services/charts/kong-*.tgz
helm/common-services/charts/postgresql-*.tgz
helm/common-services/charts/redis-*.tgz
helm/**/values.*.local.yaml
helm/**/secrets.yaml.bak

# OpenTofu / Terraform state and locals
opentofu/**/.terraform/
opentofu/**/*.tfstate
opentofu/**/*.tfstate.*
opentofu/**/*.tfvars
opentofu/**/.terraform.lock.hcl
opentofu/**/.terragrunt-cache/

# Generated by the output module — recreated on every `terragrunt apply`.
opentofu/aws/**/common-services-values.yaml
opentofu/aws/**/signals-values.yaml
opentofu/aws/**/aggregator-values.yaml
opentofu/aws/**/monitoring-values.yaml
# Legacy single combined file (pre-split) — still ignore if present locally.
opentofu/aws/**/global-cloud-values.yaml
tf.sh

# Editor / OS junk
.DS_Store
.idea/
.vscode/
*.swp
*~

# devops/
support-scripts/

# Local-only docs (kept out of version control)
docs/
opentofu/aws/dev/*

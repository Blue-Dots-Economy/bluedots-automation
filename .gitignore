# Helm packaged artifacts (regenerated by `helm dependency build`).
# Keep Chart.lock committed for reproducibility.
helm/**/*.tgz
helm/**/charts/*/charts/*.tgz

# Helm install-time generated secrets / overrides (never commit).
helm/**/values.local.yaml
helm/**/values.*.local.yaml
helm/**/secrets.yaml.bak

# OpenTofu / Terraform state and locals
opentofu/**/.terraform/
opentofu/**/*.tfstate
opentofu/**/*.tfstate.*
opentofu/**/*.tfvars
opentofu/**/.terraform.lock.hcl
opentofu/**/.terragrunt-cache/

# Generated by the output module — recreated on every `terragrunt apply`.
opentofu/aws/**/common-services-values.yaml
opentofu/aws/**/signals-values.yaml
opentofu/aws/**/aggregator-values.yaml
# Legacy single combined file (pre-split) — still ignore if present locally.
opentofu/aws/**/global-cloud-values.yaml

# Editor / OS junk
.DS_Store
.idea/
.vscode/
*.swp
*~

# temp files
DOCUMENT/*
